                        <input type="text" required value={checkoutPhone} onChange={(e) => setCheckoutPhone(e.target.value)} className="block w-full px-3 py-2 border rounded-md shadow-sm sm:text-sm focus:ring-orange-500 focus:border-orange-500" />
