                      <input type="text" required value={checkoutAddress} onChange={(e) => setCheckoutAddress(e.target.value)} className="block w-full px-3 py-2 border rounded-md shadow-sm sm:text-sm focus:ring-orange-500 focus:border-orange-500" />
