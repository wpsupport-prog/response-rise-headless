                      <div>
                        <label className="block text-xs font-semibold text-gray-500 uppercase mb-1">First name *</label>
                        <input type="text" required value={checkoutFirstName} onChange={(e) => setCheckoutFirstName(e.target.value)} className="block w-full px-3 py-2 border rounded-md shadow-sm sm:text-sm focus:ring-orange-500 focus:border-orange-500" />
