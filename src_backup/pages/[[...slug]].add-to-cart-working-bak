                          <div>
                            <label className="block text-xs font-semibold text-gray-500 uppercase mb-1">ZIP / Postcode *</label>
                            <input type="text" required={shipToDifferentAddress} value={shippingPostcode} onChange={(e) => setShippingPostcode(e.target.value)} className="block w-full px-3 py-2 border rounded-md shadow-sm sm:text-sm focus:ring-orange-500" />
