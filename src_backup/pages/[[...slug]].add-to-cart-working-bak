                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      <div>
                        <label className="block text-xs font-semibold text-gray-500 uppercase mb-1">Town / City *</label>
                        <input type="text" required value={checkoutCity} onChange={(e) => setCheckoutCity(e.target.value)} className="block w-full px-3 py-2 border rounded-md shadow-sm sm:text-sm focus:ring-orange-500 focus:border-orange-500" />
